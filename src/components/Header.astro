---
const navItems = [
  { to: '/about', label: 'About' },
  { to: '/projects', label: 'Projects' },
  { to: '/experience', label: 'Experience' },
  { to: '/problem', label: 'Problem' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="/"
      class="font-bold text-lg tracking-tight text-gray-900 hover:text-[#0a66c2] transition-colors"
    >
      tatsuki.dev
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <li>
          <a
            href={item.to}
            class="text-gray-600 hover:text-[#0a66c2] transition-colors text-sm"
            aria-current={pathname === item.to ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/contact"
          class="px-4 py-2 rounded-lg text-sm font-medium text-white transition-colors"
          style="background:#0a66c2"
        >
          Request
        </a>
      </li>
    </ul>

    <button
      id="header-menu-toggle"
      type="button"
      class="md:hidden p-2 text-gray-600 hover:text-gray-900"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="header-mobile-menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="header-mobile-menu"
    class="md:hidden bg-white border-t border-gray-100 hidden"
  >
    <ul class="px-6 py-4 space-y-4">
      {navItems.map((item) => (
        <li>
          <a
            href={item.to}
            class="block text-gray-600 hover:text-[#0a66c2] transition-colors text-sm"
            aria-current={pathname === item.to ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/contact"
          class="block text-gray-600 hover:text-[#0a66c2] transition-colors text-sm"
        >
          Request
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('header-menu-toggle');
  const menu = document.getElementById('header-mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
  }
</script>
