---
// A MacBook-style frame that renders a live site (or any URL) inside a
// scaled-down browser viewport. The iframe is laid out at `base` px wide so the
// embedded site shows its desktop layout, then scaled down to fit the screen.
interface Props {
  /** URL loaded inside the screen. */
  src: string;
  /** Where the frame links to when clicked. Defaults to `src`. */
  href?: string;
  /** Text shown in the browser address bar. Defaults to the host of `src`. */
  url?: string;
  /** Accessible label / iframe title. */
  title?: string;
  /** Virtual render width of the embedded page (its layout viewport). */
  base?: number;
  /** Extra classes for the outer <figure>. */
  class?: string;
}

const {
  src,
  href = src,
  url,
  title = 'ライブプレビュー',
  base = 1280,
  class: className = '',
} = Astro.props;

let displayUrl = url;
if (!displayUrl) {
  try {
    displayUrl = new URL(src).host;
  } catch {
    displayUrl = src;
  }
}

const iframeHeight = Math.round((base * 10) / 16);
---

<figure class={`macbook-frame select-none ${className}`}>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="group block focus:outline-none"
    aria-label={`${title}（新しいタブで開く）`}
  >
    <!-- Lid / screen -->
    <div
      class="relative mx-auto rounded-t-2xl bg-gray-900 p-[2%] shadow-[0_24px_60px_-20px_rgba(0,0,0,0.45)] ring-1 ring-black/10"
    >
      <!-- camera -->
      <div
        class="absolute left-1/2 top-[0.9%] h-1 w-1 -translate-x-1/2 rounded-full bg-gray-700"
      >
      </div>
      <!-- screen -->
      <div class="overflow-hidden rounded-lg bg-white">
        <!-- browser chrome -->
        <div
          class="flex items-center gap-2 border-b border-gray-200 bg-gray-100 px-3 py-2"
        >
          <span class="flex gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
          </span>
          <span
            class="mx-auto flex max-w-[70%] items-center gap-1.5 truncate rounded-md bg-white px-3 py-1 text-[11px] text-gray-500 ring-1 ring-gray-200"
          >
            <svg
              class="h-3 w-3 flex-shrink-0 text-gray-400"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <span class="truncate">{displayUrl}</span>
          </span>
        </div>
        <!-- content -->
        <div
          class="mb-screen-content relative aspect-[16/10] w-full overflow-hidden bg-gray-50"
          data-mb-base={base}
        >
          <iframe
            src={src}
            title={title}
            loading="lazy"
            scrolling="no"
            referrerpolicy="no-referrer"
            class="mb-iframe pointer-events-none absolute left-0 top-0 origin-top-left border-0"
            style={`width:${base}px;height:${iframeHeight}px;`}
            tabindex="-1"
            aria-hidden="true"></iframe>
          <!-- hover overlay -->
          <div
            class="pointer-events-none absolute inset-0 flex items-center justify-center bg-gray-900/0 opacity-0 transition duration-200 group-hover:bg-gray-900/40 group-hover:opacity-100"
          >
            <span
              class="rounded-full bg-white/95 px-4 py-2 text-sm font-medium text-gray-900 shadow-lg"
            >
              サイトを開く ↗
            </span>
          </div>
        </div>
      </div>
    </div>
    <!-- Base / hinge -->
    <div
      class="relative left-1/2 h-[14px] w-[106%] -translate-x-1/2 rounded-b-[10px] bg-gradient-to-b from-[#d9dbe0] to-[#a9adb6] shadow-[0_8px_14px_-6px_rgba(0,0,0,0.4)]"
    >
      <div
        class="absolute left-1/2 top-0 h-2 w-[12%] -translate-x-1/2 rounded-b-md bg-[#9498a1]"
      >
      </div>
    </div>
  </a>
</figure>

<script>
  function fit(el: Element) {
    const base = Number((el as HTMLElement).dataset.mbBase) || 1280;
    const iframe = el.querySelector<HTMLIFrameElement>('.mb-iframe');
    if (!iframe) return;
    const scale = (el as HTMLElement).clientWidth / base;
    iframe.style.transform = `scale(${scale})`;
  }

  const frames = document.querySelectorAll('.mb-screen-content');
  if ('ResizeObserver' in window) {
    const ro = new ResizeObserver((entries) => {
      for (const entry of entries) fit(entry.target);
    });
    frames.forEach((f) => ro.observe(f));
  } else {
    const run = () => frames.forEach(fit);
    run();
    window.addEventListener('resize', run);
  }
  frames.forEach(fit);
</script>
