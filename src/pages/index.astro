---
import BaseLayout from '../layouts/BaseLayout.astro';
import NoiseCanvas from '../islands/NoiseCanvas.tsx';
import RoleTyper from '../islands/RoleTyper.tsx';
import { GitHubIcon, InstagramIcon } from '../components/Icons';
import { getTechIcon } from '../lib/techIcons';

const ASCII_LINES = [
  '████████╗ █████╗ ████████╗███████╗██╗   ██╗██╗  ██╗██╗',
  '╚══██╔══╝██╔══██╗╚══██╔══╝██╔════╝██║   ██║██║ ██╔╝██║',
  '   ██║   ███████║   ██║   ███████╗██║   ██║█████╔╝ ██║',
  '   ██║   ██╔══██║   ██║   ╚════██║██║   ██║██╔═██╗ ██║',
  '   ██║   ██║  ██║   ██║   ███████║╚██████╔╝██║  ██╗██║',
  '   ╚═╝   ╚═╝  ╚═╝   ╚═╝   ╚══════╝ ╚═════╝ ╚═╝  ╚═╝╚═╝',
];

const FEATURED = [
  {
    id: '01',
    to: '/projects/yamatomo',
    title: 'Yamatomo',
    sub: '登山者のコミュニティアプリ。iOS + Web 並行開発。',
    tags: ['SwiftUI', 'React', 'Firebase'],
    accent: '#059669',
    kind: 'iOS / Web App',
  },
  {
    id: '02',
    to: '/projects/atcoder',
    title: 'AtCoder',
    sub: 'Algorithm 茶 / Heuristic 青（1603）。約2年継続中。',
    tags: ['Python', 'C++'],
    accent: '#d97706',
    kind: 'Competitive Prog.',
  },
  {
    id: '03',
    to: '/projects/math',
    title: 'Burgers 方程式',
    sub: '進行波解の安定性を扱う卒業研究の数式サイト。',
    tags: ['TypeScript', 'Vite', 'KaTeX'],
    accent: '#7c3aed',
    kind: 'Research / Math',
  },
  {
    id: '04',
    to: '/projects/mbti-app',
    title: 'MBTI × AI',
    sub: '物語形式の MBTI 診断 × 生成AI。',
    tags: ['Rails', 'OpenAI', 'Redis'],
    accent: '#4f46e5',
    kind: 'Web App / LLM',
  },
];

const HOME_DESCRIPTION =
  '北村健紀（Tatsuki Kitamura）のポートフォリオ。早稲田大学教育学部数学科4年。Ruby on Rails / React / SwiftUI を中心に Web・iOS アプリ開発、AtCoder（Algorithm 茶 / Heuristic 青）に取り組んでいます。';
---

<BaseLayout title="ポートフォリオ" description={HOME_DESCRIPTION} path="/">
  <section class="relative overflow-hidden">
    <NoiseCanvas client:load />
    <div class="relative max-w-5xl mx-auto px-6 pt-32 pb-12">
      <div class="font-mono text-[11px] text-gray-500 tracking-[0.22em] mb-5 animate-fade-in">
        <span class="text-[#0a66c2]">●</span>&nbsp;&nbsp;ONLINE — TOKYO
      </div>

      <div
        class="font-mono text-gray-900 animate-fade-in animation-delay-100 inline-block"
        style="font-size:clamp(8px,2.4vw,13px);line-height:1;letter-spacing:0;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace"
      >
        {ASCII_LINES.map((line, i) => (
          <div
            class="whitespace-pre"
            style={`margin-left:${(ASCII_LINES.length - 1 - i) * 0.6}em`}
          >
            {line}
          </div>
        ))}
      </div>

      <div class="mt-7 flex items-baseline gap-3 font-mono text-base sm:text-lg animate-fade-in animation-delay-200">
        <span class="text-gray-400">&gt;</span>
        <span class="text-gray-900">I am a</span>
        <RoleTyper client:load />
      </div>

      <div class="mt-3 font-mono text-xs sm:text-sm text-gray-500 animate-fade-in animation-delay-300">
        // Rails / React / SwiftUI
      </div>

      <div class="mt-7 flex flex-nowrap gap-2 sm:gap-3 font-mono text-[11px] sm:text-sm animate-fade-in animation-delay-400">
        <a
          href="/projects"
          class="px-3 sm:px-5 py-2 sm:py-2.5 rounded text-white font-semibold tracking-wide bg-[#0a66c2] hover:bg-[#004182] transition-colors whitespace-nowrap"
        >
          projects
        </a>
        <a
          href="/experience"
          class="px-3 sm:px-5 py-2 sm:py-2.5 rounded border border-gray-300 bg-white text-gray-900 font-medium hover:border-gray-500 transition-colors whitespace-nowrap"
        >
          experience
        </a>
        <a
          href="https://github.com/tatsukikitamura"
          target="_blank"
          rel="noopener noreferrer"
          class="px-3 sm:px-5 py-2 sm:py-2.5 rounded border border-gray-300 bg-white text-gray-900 font-medium hover:border-gray-500 transition-colors inline-flex items-center gap-1.5 sm:gap-2 whitespace-nowrap"
        >
          <GitHubIcon className="w-3.5 h-3.5 sm:w-4 sm:h-4" /> github
        </a>
        <a
          href="https://instagram.com/t4t2uk1/"
          target="_blank"
          rel="noopener noreferrer"
          class="px-3 sm:px-5 py-2 sm:py-2.5 rounded border border-gray-300 bg-white text-gray-900 font-medium hover:border-gray-500 transition-colors inline-flex items-center gap-1.5 sm:gap-2 whitespace-nowrap"
        >
          <InstagramIcon className="w-3.5 h-3.5 sm:w-4 sm:h-4" gradient /> instagram
        </a>
      </div>
    </div>
  </section>

  <section class="px-6 py-14">
    <div class="max-w-5xl mx-auto">
      <div class="font-mono text-[11px] text-gray-500 tracking-[0.22em] mb-4">
        ━━━ FEATURED WORK ━━━
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {FEATURED.map((p) => (
          <a
            href={p.to}
            class="group relative block overflow-hidden border border-gray-200 bg-white p-5 rounded-lg font-mono transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-[var(--accent)]"
            style={`--accent:${p.accent}`}
          >
            <span
              class="absolute inset-x-0 top-0 h-[3px] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300"
              style="background:var(--accent)"
            />
            <span
              class="absolute -right-3 -top-4 text-[5rem] font-extrabold leading-none select-none pointer-events-none transition-opacity duration-300 opacity-[0.07] group-hover:opacity-[0.13]"
              style="color:var(--accent);font-family:Sora,system-ui,sans-serif"
            >
              {p.id}
            </span>

            <div class="relative">
              <div class="flex items-center justify-between mb-3">
                <span
                  class="inline-flex items-center justify-center w-7 h-7 rounded text-[11px] font-bold text-white"
                  style="background:var(--accent)"
                >
                  {p.id}
                </span>
                <span class="text-[10px] tracking-wider uppercase text-gray-400">
                  {p.kind}
                </span>
              </div>
              <div
                class="text-lg font-bold text-gray-900 mb-1.5 group-hover:text-[var(--accent)] transition-colors"
                style="font-family:Sora,system-ui,sans-serif"
              >
                {p.title}
              </div>
              <div
                class="text-xs text-gray-600 mb-4 leading-relaxed"
                style="font-family:Sora,system-ui,sans-serif"
              >
                {p.sub}
              </div>
              <div class="flex flex-wrap items-center gap-3 pt-3 border-t border-gray-100">
                {p.tags.map((t) => {
                  const icon = getTechIcon(t);
                  return icon ? (
                    <img
                      src={icon}
                      class="w-6 h-6 flex-shrink-0"
                      alt={t}
                      title={t}
                      loading="lazy"
                    />
                  ) : (
                    <span class="text-xs font-semibold tracking-wide" style="color:var(--accent)">
                      {t}
                    </span>
                  );
                })}
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-7 font-mono text-xs text-gray-500">
        <a href="/projects" class="text-[#0a66c2] hover:underline">
          $ ls projects/ --all →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
