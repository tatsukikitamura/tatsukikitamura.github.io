---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../style.css';

type Props = {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
};

const SITE_NAME = '北村健紀 (Tatsuki Kitamura)';
const ORIGIN = 'https://tatsuki.dev';
const DEFAULT_DESCRIPTION =
  '北村健紀（Tatsuki Kitamura）のポートフォリオサイト。早稲田大学教育学部数学科4年。Ruby on Rails / React / SwiftUI を中心に Web・iOS アプリ開発、AtCoder（Algorithm 茶 / Heuristic 青）に取り組んでいます。';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  path = Astro.url.pathname,
  ogImage = `${ORIGIN}/images/main.jpg`,
} = Astro.props;

const fullTitle = `${title} | ${SITE_NAME}`;
const canonical = `${ORIGIN}${path === '/' ? '/' : path.replace(/\/$/, '')}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="北村健紀 (Tatsuki Kitamura)" />
    <meta
      name="keywords"
      content="北村健紀, Tatsuki Kitamura, きたむらたつき, 早稲田大学, ポートフォリオ, Webエンジニア, Ruby on Rails, React, SwiftUI, AtCoder"
    />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="tatsuki.dev" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: '北村健紀',
      alternateName: ['Tatsuki Kitamura', 'きたむらたつき', 'Kitamura Tatsuki'],
      url: 'https://tatsuki.dev/',
      image: 'https://tatsuki.dev/images/main.jpg',
      jobTitle: 'Software Engineer',
      description:
        '早稲田大学教育学部数学科4年。Web・iOS アプリ開発、競技プログラミングに取り組んでいます。',
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: '早稲田大学',
        sameAs: 'https://www.waseda.jp/',
      },
      knowsAbout: [
        'Ruby on Rails',
        'React',
        'SwiftUI',
        'Python',
        'C++',
        'FastAPI',
        'PostgreSQL',
        '競技プログラミング',
      ],
      sameAs: [
        'https://github.com/tatsukikitamura',
        'https://atcoder.jp/users/oreccchi',
      ],
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'tatsuki.dev',
      url: 'https://tatsuki.dev/',
      inLanguage: 'ja',
      author: { '@type': 'Person', name: '北村健紀' },
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-MWZJZWMLW8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-MWZJZWMLW8');
    </script>
  </head>
  <body>
    <div class="min-h-screen flex flex-col bg-white">
      <Header />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
